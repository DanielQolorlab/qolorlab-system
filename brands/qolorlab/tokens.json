{
  "colors": {
    "Background/Base": "#080808",
    "Background/Surface": "#111318",
    "Text/Primary": "#fcfcfd",
    "Text/Secondary": "#8f9ca3",
    "Accent/Red": "#FD0611",
    "Stroke/Default": "rgba(255, 255, 255, 0.10)"
  },
  "typography": {
    "Type/Display": {
      "fontFamily": "Neue Haas Grotesk Display Pro",
      "fontStyle": "55 Roman",
      "fontSize": 64,
      "lineHeight": 72,
      "letterSpacing": -1.5
    },
    "Type/Heading": {
      "fontFamily": "Neue Haas Grotesk Display Pro",
      "fontStyle": "65 Medium",
      "fontSize": 32,
      "lineHeight": 40,
      "letterSpacing": -0.5
    },
    "Type/Body": {
      "fontFamily": "Neue Haas Grotesk Display Pro",
      "fontStyle": "45 Light",
      "fontSize": 15,
      "lineHeight": 24,
      "letterSpacing": 0
    },
    "Type/Small": {
      "fontFamily": "Neue Haas Grotesk Display Pro",
      "fontStyle": "45 Light",
      "fontSize": 12,
      "lineHeight": 18,
      "letterSpacing": 0.2
    }
  },
  "spacing": {
    "t-1": 4,
    "t-2": 8,
    "t-3": 12,
    "t-4": 16,
    "t-5": 24,
    "t-6": 32,
    "t-7": 48,
    "t-8": 64,
    "t-9": 96,
    "t-10": 128
  },
  "radius": {
    "none": 0,
    "sm": 4,
    "md": 8,
    "lg": 16,
    "full": 9999
  },
  "semantic": {
    "background": {
      "base":    "{colors.Background/Base}",
      "surface": "{colors.Background/Surface}"
    },
    "text": {
      "primary":   "{colors.Text/Primary}",
      "secondary": "{colors.Text/Secondary}"
    },
    "accent": {
      "primary": "{colors.Accent/Red}"
    },
    "border": {
      "default": "{colors.Stroke/Default}"
    }
  }
}
